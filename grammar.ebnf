/* 1. ROOT DOCUMENT STRUCTURE */
UrkelFile        ::= { TriviaLine }
                     [ MachineDecl { TriviaLine } ]
                     { ComposeDecl { TriviaLine } }
                     [ FactoryDecl { TriviaLine } ]
                     StatesBlock { TriviaLine }
                     TransitionsBlock
                     { TriviaLine }

/* 2. TOP-LEVEL DECLARATIONS & BLOCKS */
MachineDecl      ::= { Whitespace } "machine" Whitespace Identifier [ ContextDecl ] Newline
ContextDecl      ::= "<" { Whitespace } Identifier { Whitespace } ">"

/* @compose <Name> — declares that this machine owns and lifecycle-manages a sub-FSM.
   Multiple @compose declarations are allowed (one per sub-machine).
   
   Code generation (US-11.4 actor bridge pattern):
     For each composed machine "Foo", the generator emits:
       • private actor SubFSMFoo — owns a consuming FooMachine<FooStateIdle> wrapped in a
         ~Copyable Phase enum; exposes start()/stop()/error(_:) lifecycle methods.
         The actor uses a takePhase() helper (via withUnsafeMutablePointer) to work around
         the Swift 6.3 limitation that actor stored properties are not directly consumable.
       • ClientRuntime gains: typealias MakeFoo / let makeFoo: MakeFoo
       • fromRuntime creates SubFSMFoo actors and wraps each parent transition hook to call
         the appropriate sub-machine lifecycle method before the user's hook.
     
   Lifecycle mapping (parent → sub-machine actor method):
     Transition FROM the initial parent state → SubFSMFoo.start()
     Transition with an Error-typed parameter  → SubFSMFoo.error(_:)
     All other transitions                     → SubFSMFoo.stop()
*/
ComposeDecl      ::= { Whitespace } "@compose" Whitespace Identifier Newline

FactoryDecl      ::= { Whitespace } "@factory" Whitespace Identifier "(" [ ParameterList ] ")" Newline

StatesBlock      ::= { Whitespace } "@states" Newline { TriviaLine | StateStmt }
TransitionsBlock ::= { Whitespace } "@transitions" Newline { TriviaLine | TransitionStmt }

/* 3. STATES & TRANSITIONS */
StateStmt        ::= { Whitespace } StateKind Whitespace Identifier { Whitespace } Newline
StateKind        ::= "init" | "state" | "final"

TransitionStmt   ::= { Whitespace } Identifier
                     { Whitespace } "->" { Whitespace }
                     EventDecl
                     { Whitespace } "->" { Whitespace }
                     Identifier
                     [ { Whitespace } "=>" { Whitespace } Identifier ".init" ]
                     { Whitespace } Newline

EventDecl        ::= Identifier [ "(" [ ParameterList ] ")" ]

/* 4. PARAMETERS & TYPES */
ParameterList    ::= Parameter { { Whitespace } "," { Whitespace } Parameter }
Parameter        ::= Identifier { Whitespace } ":" { Whitespace } SwiftType

/* 5. TRIVIA AND LEXICAL TOKENS */
TriviaLine       ::= BlankLine | CommentLine
BlankLine        ::= { Whitespace } Newline
CommentLine      ::= { Whitespace } Comment Newline

Identifier       ::= Letter { Letter | Digit | "_" }
SwiftType        ::= Any valid Swift type string (e.g., "URL", "Int", "[String: Any]?")

Comment          ::= "#" { Any character except Newline }
Letter           ::= "A".."Z" | "a".."z"
Digit            ::= "0".."9"
Whitespace       ::= " " | "\t"
Newline          ::= "\n" | "\r\n"
