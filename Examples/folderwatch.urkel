# FolderWatch.urkel
@imports
  import Foundation
  import Dependencies

@factory makeObserver(directory: URL, debounceMs: Int)

@states
  init Idle
  state Running
  final Stopped

@transitions
  # [Current]   -> [Trigger(Payload)]   -> [Next]
  Idle         -> start                  -> Running
  Running      -> stop                   -> Stopped
